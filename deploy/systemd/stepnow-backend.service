[Unit]
Description=StepNow FastAPI backend
After=network.target

[Service]
User=root
WorkingDirectory=/root/stepnow/apps/backend
EnvironmentFile=/root/stepnow/apps/backend/.env
Environment="PATH=/root/stepnow/apps/backend/venv/bin"
ExecStart=/root/stepnow/apps/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target